# Nucleus backend configuration template
# Copy to .env and fill in values

# --- Core infra ---
# Use Postgres in docker-compose / production. For no-infra dev, point at a
# local SQLite file instead: DATABASE_URL=sqlite+aiosqlite:///./nucleus.db
DATABASE_URL=postgresql+asyncpg://nucleus:nucleus@localhost:5432/nucleus
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production

# --- Object storage ---
S3_BUCKET=nucleus-media
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=nucleus
AWS_SECRET_ACCESS_KEY=nucleus123
AWS_REGION=us-east-1

# --- NeuroPeer integration ---
# NeuroPeer runs on port 8001 in dev; Nucleus itself uses 8000.
NEUROPEER_BASE_URL=http://localhost:8001
# Required when the NeuroPeer instance has API key auth enabled (the middleware
# described in LOCAL_DEV.md). Must match one of the comma-separated values in
# that instance's NEUROPEER_API_KEYS. Leave blank when the server is open.
NEUROPEER_API_KEY=
# NEUROPEER_TIMEOUT_SECONDS=300 # HTTP request timeout

# --- ComfyUI execution service ---
# Open-weights diffusion/audio engine. Host access uses 8188; inside
# docker-compose it's http://comfyui:8188.
COMFYUI_BASE_URL=http://localhost:8188
# COMFYUI_API_KEY=  # Currently unused — ComfyUI is unauthenticated

# --- Remotion render service ---
# Host access (running docker-compose locally): host port 3101 -> container 8089.
# Inside docker-compose it's http://remotion:8089.
REMOTION_API_URL=http://localhost:3101

# --- Ruflo agent bridge ---
# URL of the Node Ruflo bridge (agent/server.ts). Docker maps 9100 -> 9000.
RUFLO_BRIDGE_URL=http://localhost:9100
# Base URL the bridge uses to call back into the Nucleus tool endpoints.
NUCLEUS_API_URL=http://localhost:8000

# --- Provider API keys (leave blank to use mocks) ---
NUCLEUS_MOCK_PROVIDERS=true
FAL_KEY=
ATLAS_CLOUD_API_KEY=
WAVESPEED_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_PROJECT=

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
