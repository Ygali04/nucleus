# Nucleus backend configuration template
# Copy to .env and fill in values

# --- Core infra ---
# Use Postgres in docker-compose / production. For no-infra dev, point at a
# local SQLite file instead: DATABASE_URL=sqlite+aiosqlite:///./nucleus.db
DATABASE_URL=postgresql+asyncpg://nucleus:nucleus@localhost:5432/nucleus
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production

# --- Object storage ---
S3_BUCKET=nucleus-media
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=nucleus
AWS_SECRET_ACCESS_KEY=nucleus123
AWS_REGION=us-east-1

# --- NeuroPeer integration ---
NEUROPEER_BASE_URL=http://localhost:8000

# --- Provider API keys (leave blank to use mocks) ---
NUCLEUS_MOCK_PROVIDERS=true
FAL_KEY=
ATLAS_CLOUD_API_KEY=
WAVESPEED_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_CLOUD_PROJECT=

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
