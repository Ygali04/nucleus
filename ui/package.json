{
  "name": "nucleus-pipeline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"fixtures/**/*.ts\" \"hooks/**/*.ts\" \"lib/**/*.ts\" \"store/**/*.ts\" \"*.{json,mjs,ts}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"fixtures/**/*.ts\" \"hooks/**/*.ts\" \"lib/**/*.ts\" \"store/**/*.ts\" \"*.{json,mjs,ts}\""
  },
  "dependencies": {
    "@xyflow/react": "^12.10.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-window": "^2.2.7",
    "recharts": "^3.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
